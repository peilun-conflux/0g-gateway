# Environment-variable configuration for zgs-gateway.
#
# Every setting also exists as a key in config.example.yaml. Values are resolved
# as: built-in defaults -> config file -> environment variables, so anything set
# here overrides the config file. The gateway runs from these variables alone
# (no config file required); env vars are also handy for injecting secrets such
# as ZGS_PRIVATE_KEY into a container.

# --- Required ---
# Storage-node JSON-RPC endpoints (comma-separated).
ZGS_NODES=http://47.84.224.253:5678,http://47.84.225.228:5678
# Host-chain RPC (e.g. Conflux eSpace testnet).
ZGS_ETH_RPC=https://evmtestnet.confluxrpc.com
# Signer private key (hex, no 0x prefix). Keep it in a secrets manager; never commit it.
ZGS_PRIVATE_KEY=

# --- Optional ---
# Listen address; this is the S3-compatible endpoint (gofakes3) that OBS/S3 SDK
# clients connect to. Signatures are NOT verified, so bind it internal-only:
# prefer 127.0.0.1:8080; never 0.0.0.0 or a public address.
ZGS_GW_LISTEN=:8080
ZGS_GW_DATA_DIR=./data
# Max object size in bytes (default 4 GiB).
ZGS_GW_MAX_SIZE=
# Local cache cap in bytes (default 10 GiB); 0 = unbounded. Finalized objects are
# evicted LRU (restored from 0G on the next read); when the cache fills with
# not-yet-finalized objects (which can't be evicted), new uploads get 503 SlowDown.
ZGS_GW_CACHE_MAX_BYTES=
# On-chain batch size / worker flush interval (ms, must be > 0) / retry ceiling.
ZGS_GW_BATCH_MAX=20
ZGS_GW_FLUSH_INTERVAL_MS=3000
ZGS_GW_MAX_RETRIES=5
# Desired replica count (default = number of nodes).
ZGS_EXPECTED_REPLICA=
