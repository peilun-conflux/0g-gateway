# --- 必填 ---
# 存储节点 JSON-RPC（逗号分隔）
ZGS_NODES=http://47.84.224.253:5678,http://47.84.225.228:5678
# 宿主链 RPC（Conflux eSpace testnet）
ZGS_ETH_RPC=https://evmtestnet.confluxrpc.com
# 出证账户私钥（hex，无 0x 前缀）。生产放 KMS/vault，勿提交进仓库
ZGS_PRIVATE_KEY=

# --- 可选 ---
ZGS_GW_LISTEN=:8080
ZGS_GW_DATA_DIR=./data
# 下载签名 token 密钥；留空 = 读接口不鉴权（仅限内网试用）
ZGS_GW_AUTH_SECRET=
# 逻辑删除接口密钥；留空 = DELETE 禁用
ZGS_GW_ADMIN_SECRET=
# 单对象大小上限（字节），默认 4GiB
ZGS_GW_MAX_SIZE=
# 攒批上限 / 刷新间隔 / 重试上限
ZGS_GW_BATCH_MAX=20
ZGS_GW_FLUSH_INTERVAL_MS=3000
ZGS_GW_MAX_RETRIES=5
# 期望副本数，默认 = 节点数
ZGS_EXPECTED_REPLICA=
